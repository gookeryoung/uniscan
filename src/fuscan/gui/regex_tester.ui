   </item>
   <item>
    <widget class="QTextEdit" name="regex_cheatsheet_view">
     <property name="readOnly">
      <bool>true</bool>
     </property>
     <property name="fontFamily" stdset="0">
      <string>Consolas</string>
     </property>
    </widget>
   </item>
   <item>
    <widget class="QPushButton" name="close_btn">
     <property name="text">
      <string>关闭</string>
     </property>
    </widget>
   </item>
  </layout>
 </widget>
 <resources/>
 <connections>
  <connection>
   <sender>close_btn</sender>
   <signal>clicked()</signal>
